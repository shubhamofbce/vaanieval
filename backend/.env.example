APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
FRONTEND_APP_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# LOCAL DEVELOPMENT: SQLite
# DATABASE_URL=sqlite:///./backend.db

# PRODUCTION: PostgreSQL
# Example: postgresql://user:password@host:5432/vaanieval?sslmode=require
DATABASE_URL=

SECRET_KEY=change-me
CREDENTIAL_ENCRYPTION_KEY=

# Cron job security token (used to call /api/v1/worker/drain)
# Set a strong random value for production
CRON_SECRET=

# API endpoints
ELEVENLABS_API_BASE=https://api.elevenlabs.io
VAPI_API_BASE=https://api.vapi.ai
OPENAI_API_BASE=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
# Allows time for a local model to load before evaluation.
OLLAMA_REQUEST_TIMEOUT_SECONDS=300

# Vercel deployment detection (automatically set by Vercel)
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app
